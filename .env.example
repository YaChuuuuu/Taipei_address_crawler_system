# ── 執行環境 ────────────────────────────────────────────────────
# Docker 環境設為 true，本機開發設為 false
RUNNING_IN_DOCKER=true

# ── 資料路徑 ────────────────────────────────────────────────────
# 爬蟲資料、CSV、log 的存放目錄
DATA_PATH=./data/

# ── 爬蟲設定 ────────────────────────────────────────────────────
TARGET_URL=https://www.ris.gov.tw/app/portal/3053
# 民國年格式，例如 114-01-01
DATE_START=114-01-01
DATE_END=114-12-31
# 可選值：門牌初編 / 門牌改編 / 門牌廢止
QUERY_TYPE=門牌初編
# 驗證碼辨識失敗最大重試次數
MAX_RETRY=10

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=crawler
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ── 服務連線 ────────────────────────────────────────────────────
LOKI_URL=http://loki:3100
CRAWLER_URL=http://crawler:8001

# ── 異常通知（Email）───────────────────────────────────────────
# Gmail 請使用應用程式密碼（需開啟兩步驟驗證）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL=
# 同一冷卻期內只送一封，單位：秒（預設 300）
NOTIFY_COOLDOWN=300
